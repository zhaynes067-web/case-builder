{
  "compilerOptions": {
    "target": "es2022",
    "useDefineForClassFields": false,
    "module": "commonjs",
    "lib": ["es2022", "dom"],
    "declaration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
